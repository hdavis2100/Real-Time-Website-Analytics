# Node / API
PORT=3000
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=poker-action-platform-api
KAFKA_TOPIC_SIMULATION_REQUESTS=poker.simulation_requests
KAFKA_TOPIC_ACTIONS=poker.actions
KAFKA_TOPIC_HAND_SUMMARIES=poker.hand_summaries
KAFKA_TOPIC_SIMULATION_EVENTS=poker.simulation_events
KAFKA_CREATE_TOPIC=true
KAFKA_TOPIC_PARTITIONS=6
KAFKA_TOPIC_REPLICATION_FACTOR=1
APP_DATABASE_URL=postgresql://poker:poker@postgres:5432/poker_app
APP_SESSION_TTL_DAYS=14
REDIS_URL=redis://redis:6379/0

# Python / platform
PYTHONPATH=.
POKER_PLATFORM_RUNTIME_DIR=runtime
POKER_PLATFORM_SQL_DIR=sql
POKER_PLATFORM_SCHEMA_VERSION=1

# Historical ingest
HISTORICAL_FIXTURE_PATH=sample_data/historical/handhq_6max_sample.phhs
# Set this to a local PHH directory/file, a .zip/.tar archive, or an HTTP(S) dataset URL.
PHH_DATASET_SOURCE=sample_data/historical/handhq_6max_sample.phhs
PHH_CACHE_DIR=runtime/phh_cache

# Simulator
SIM_DEFAULT_HANDS=25
SIM_DEFAULT_SEED=42
SIM_DEFAULT_BLIND_BB=1.0
SIM_DEFAULT_SMALL_BLIND_BB=0.5
SIM_DEFAULT_STARTING_STACK_BB=100
SIM_DEFAULT_BACKEND=llm_gated_nano

# Streaming
STREAM_CHECKPOINT_PATH=runtime/stream_checkpoints/poker
KAFKA_STREAM_STARTING_OFFSETS=latest
STREAM_WATERMARK=5 minutes
STREAM_WINDOW_DURATION=1 minute
STREAM_SLIDE_DURATION=30 seconds
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.8
APP_INTERNAL_BASE_URL=http://app:3000
SIMULATION_WORKER_LEGACY_REGISTRY_ENABLED=false
SIMULATION_WORKER_CONCURRENCY=6
SIMULATION_WORKER_MAX_POLL_INTERVAL_MS=1800000

# Dashboard
DASHBOARD_PORT=8501

# Airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__SIMPLE_AUTH_MANAGER_ALL_ADMINS=True
AIRFLOW_CONN_SPARK_DEFAULT=spark://spark-master:7077?deploy-mode=client&spark_binary=spark-submit
SNOWFLAKE_WAREHOUSE_KEEP_WARM_SECONDS=600

# Snowflake
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_ROLE=
SNOWFLAKE_PRIVATE_KEY_FILE=secrets/snowflake/rsa_key.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# OpenAI
OPENAI_API_KEY=

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PokerHandSummaryEvent",
  "type": "object",
  "required": [
    "payload_version",
    "event_type",
    "source_type",
    "table_id",
    "hand_id",
    "button_seat",
    "board_cards",
    "started_at",
    "finished_at",
    "winner_player_ids",
    "total_pot_bb",
    "rake_bb",
    "backend_type",
    "raw_lineage"
  ],
  "properties": {
    "payload_version": { "type": "string" },
    "event_type": { "const": "hand_summary" },
    "source_type": { "enum": ["historical", "simulated"] },
    "source_dataset": { "type": ["string", "null"] },
    "source_run_id": { "type": ["string", "null"] },
    "simulation_run_id": { "type": ["string", "null"] },
    "user_id": { "type": ["string", "null"] },
    "decision_backend": { "type": ["string", "null"], "enum": ["llm", "heuristic", null] },
    "hero_context_hash": { "type": ["string", "null"] },
    "hero_seat": { "type": ["integer", "null"], "minimum": 1, "maximum": 6 },
    "table_id": { "type": "string" },
    "hand_id": { "type": "string" },
    "button_seat": { "type": "integer", "minimum": 1, "maximum": 6 },
    "small_blind_bb": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "big_blind_bb": { "type": ["number", "null"], "exclusiveMinimum": 0 },
    "board_cards": { "type": "array", "items": { "type": "string" } },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "winner_player_ids": { "type": "array", "items": { "type": "string" } },
    "total_pot_bb": { "type": "number", "minimum": 0 },
    "rake_bb": { "type": "number", "minimum": 0 },
    "starting_stacks_bb": { "type": "object", "additionalProperties": { "type": "number" } },
    "final_stacks_bb": { "type": "object", "additionalProperties": { "type": "number" } },
    "collections_bb": { "type": "object", "additionalProperties": { "type": "number" } },
    "player_personas": { "type": "object", "additionalProperties": { "type": "string" } },
    "agent_ids": { "type": "object", "additionalProperties": { "type": "string" } },
    "player_agent_ids": { "type": "object", "additionalProperties": { "type": "string" } },
    "seats": { "type": "object", "additionalProperties": { "type": "integer" } },
    "player_seats": { "type": "object", "additionalProperties": { "type": "integer" } },
    "showdown_player_ids": { "type": "array", "items": { "type": "string" } },
    "player_hole_cards": { "type": "object", "additionalProperties": { "type": "array", "items": { "type": "string" } } },
    "backend_types": { "type": "object", "additionalProperties": { "type": "string" } },
    "backend_type": { "type": "string" },
    "raw_lineage": { "type": "object" }
  }
}

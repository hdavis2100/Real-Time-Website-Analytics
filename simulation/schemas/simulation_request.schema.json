{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SimulationRequest",
  "type": "object",
  "required": [
    "payload_version",
    "simulation_run_id",
    "table_id",
    "hand_count",
    "seed",
    "small_blind_bb",
    "big_blind_bb",
    "starting_stack_bb",
    "context"
  ],
  "properties": {
    "payload_version": { "type": "string" },
    "simulation_run_id": { "type": "string" },
    "table_id": { "type": "string" },
    "hand_count": { "type": "integer", "minimum": 1, "maximum": 5000, "default": 500 },
    "seed": { "type": "integer" },
    "small_blind_bb": { "type": "number", "exclusiveMinimum": 0 },
    "big_blind_bb": { "type": "number", "exclusiveMinimum": 0 },
    "starting_stack_bb": { "type": "number", "exclusiveMinimum": 0 },
    "context": { "type": "string", "minLength": 1 },
    "hero_seat": { "type": "integer", "minimum": 1, "maximum": 6 },
    "user_id": { "type": ["string", "null"] },
    "decision_backend": { "type": "string", "enum": ["llm", "heuristic"], "default": "llm" },
    "hero_context_hash": { "type": ["string", "null"] },
    "backend_type": { "type": "string" },
    "model_name": { "type": ["string", "null"] },
    "reasoning_effort": { "type": ["string", "null"] }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PokerActionEvent",
  "type": "object",
  "required": [
    "payload_version",
    "event_type",
    "source_type",
    "table_id",
    "hand_id",
    "action_index",
    "street",
    "player_id",
    "seat",
    "position",
    "action_type",
    "pot_before_bb",
    "pot_after_bb",
    "to_call_bb",
    "effective_stack_bb",
    "players_remaining",
    "board_cards_visible",
    "hole_cards_visible",
    "is_all_in",
    "event_ts",
    "backend_type",
    "raw_lineage"
  ],
  "properties": {
    "payload_version": { "type": "string" },
    "event_type": { "const": "action" },
    "source_type": { "enum": ["historical", "simulated"] },
    "source_dataset": { "type": ["string", "null"] },
    "source_run_id": { "type": ["string", "null"] },
    "simulation_run_id": { "type": ["string", "null"] },
    "user_id": { "type": ["string", "null"] },
    "decision_backend": { "type": ["string", "null"], "enum": ["llm", "heuristic", null] },
    "hero_context_hash": { "type": ["string", "null"] },
    "hero_seat": { "type": ["integer", "null"], "minimum": 1, "maximum": 6 },
    "is_hero_player": { "type": "boolean" },
    "table_id": { "type": "string" },
    "hand_id": { "type": "string" },
    "action_index": { "type": "integer", "minimum": 0 },
    "street": { "enum": ["preflop", "flop", "turn", "river", "showdown"] },
    "player_id": { "type": "string" },
    "agent_id": { "type": ["string", "null"] },
    "seat": { "type": "integer", "minimum": 1, "maximum": 6 },
    "position": { "type": "string" },
    "action_type": {
      "enum": [
        "post_ante",
        "post_small_blind",
        "post_big_blind",
        "fold",
        "check",
        "call",
        "bet",
        "raise",
        "all_in",
        "collect_pot",
        "show",
        "muck"
      ]
    },
    "amount_bb": { "type": ["number", "null"] },
    "pot_before_bb": { "type": "number", "minimum": 0 },
    "pot_after_bb": { "type": "number", "minimum": 0 },
    "to_call_bb": { "type": "number", "minimum": 0 },
    "effective_stack_bb": { "type": "number", "minimum": 0 },
    "players_remaining": { "type": "integer", "minimum": 1, "maximum": 6 },
    "board_cards_visible": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hole_cards_visible": {
      "type": "array",
      "items": { "type": "string" }
    },
    "is_all_in": { "type": "boolean" },
    "event_ts": { "type": "string", "format": "date-time" },
    "backend_type": { "type": "string" },
    "persona_name": { "type": ["string", "null"] },
    "persona_text": { "type": ["string", "null"] },
    "raw_lineage": { "type": "object" }
  }
}
